[Unit]
Description=Garage Controller GSM (backend GSM + interface web)
After=network.target
Wants=network.target

[Service]
# Type=notify : le process signale lui-même READY=1 au démarrage et
# WATCHDOG=1 périodiquement (voir run.py / app/utils/systemd_notify.py).
# Si le GSM reste bloqué (threads morts, reconnexion série qui échoue), le
# process arrête d'émettre WATCHDOG=1 et systemd le tue puis le redémarre
# via Restart=on-failure — filet de sécurité au-dessus des tentatives de
# récupération internes (reset logiciel, reconnexion série) du GSMService.
Type=notify
# Doit être strictement supérieur au double de l'intervalle de heartbeat
# (calculé automatiquement à WatchdogSec/2 côté run.py).
WatchdogSec=120
NotifyAccess=main
# Adapter User/WorkingDirectory si l'installation diffère.
User=__USER__
Group=__USER__
WorkingDirectory=__APP_DIR__
Environment=GARAGE_WEB_HOST=0.0.0.0
Environment=GARAGE_WEB_PORT=8080
Environment=GARAGE_LOG_LEVEL=INFO
# En production sur le Raspberry Pi, ne PAS activer GARAGE_FAKE_SERIAL.
ExecStart=__APP_DIR__/.venv/bin/python __APP_DIR__/run.py
Restart=on-failure
RestartSec=5
# Laisse le temps aux threads série/GPIO de s'arrêter proprement.
TimeoutStopSec=15
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
